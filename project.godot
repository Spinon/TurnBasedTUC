; Engine configuration file.
; Generated for: TUC - Teoria dos Universos Conectados
; Godot 4.x

config_version=5

[application]

config/name="TUC - Teoria dos Universos Conectados"
config/description="RPG de turno baseado no Livro 1 da saga Teoria dos Universos Conectados"
config/version="0.1.0"
run/main_scene="res://scenes/main_menu/MainMenu.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")
config/icon="res://assets/sprites/ui/icon.png"

[autoload]

GameManager="*res://scripts/autoload/GameManager.gd"
PartyManager="*res://scripts/autoload/PartyManager.gd"
BattleManager="*res://scripts/autoload/BattleManager.gd"
AudioManager="*res://scripts/autoload/AudioManager.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/size/resizable=false
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[rendering]

; Nearest-neighbor — essencial para pixel art 16-bit não ficar borrado
textures/canvas_textures/default_texture_filter=0

